{
  "name": "gwet",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "npx wrangler pages dev --proxy 5173 -- npm dev",
    "build": "tsc && vite build",
    "db:create": "npx wrangler d1 create gwet-db",
    "db:migrate": "npx wrangler d1 execute gwet-db --file=./schema.sql",
    "db:migrate:local": "npx wrangler d1 execute gwet-db --local --file=./schema.sql",
    "deploy": "npm run build && npx wrangler pages deploy ./dist"
  },
  "dependencies": {
    "@livekit/components-react": "^2.9.20",
    "@livekit/components-styles": "^1.2.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.98.0",
    "livekit-client": "^2.17.2",
    "livekit-server-sdk": "^2.15.0",
    "lucide-react": "^0.575.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.4",
    "typescript": "^4.1.2",
    "vite": "^7.3.1",
    "wrangler": "^4.69.0"
  }
}
